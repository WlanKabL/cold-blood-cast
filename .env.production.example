# ──────────────────────────────────────────────────────────────
# Cold Blood Cast — Production .env Template
# ──────────────────────────────────────────────────────────────
# Copy this file, fill in all values, and paste as the DOTENV
# environment secret in GitHub (Settings → Environments → production).
#
# The deploy pipeline writes this to .env on the server and
# appends BACKEND_IMAGE / FRONTEND_IMAGE automatically.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Must match DB_PASSWORD used in docker-compose.production.yml
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# DATABASE_URL is set by docker-compose.production.yml environment
# but we include it here as a fallback
DATABASE_URL=postgresql://coldblood:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/coldbloodcast?schema=public

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
HOST=0.0.0.0

# ── CORS ──────────────────────────────────────────────────────
# Your frontend domain (comma-separated for multiple origins)
CORS_ORIGIN=https://your-domain.com

# ── Frontend URL (used in emails) ─────────────────────────────
FRONTEND_URL=https://your-domain.com

# ── Auth ──────────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Password Hashing ─────────────────────────────────────────
HASH_PEPPER=CHANGE_ME_MIN_32_CHARS
HASH_ITERATIONS=100000

# ── Cookie ────────────────────────────────────────────────────
COOKIE_SECRET=CHANGE_ME_MIN_32_CHARS

# ── Encryption (AES-256 — 64 hex chars) ──────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── Uploads ───────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Data Directory (for postgres volume) ──────────────────────
DATA_DIR=./data

# ── Redis (BullMQ) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Admin Seed ────────────────────────────────────────────────
ADMIN_EMAIL=your_admin@example.com
ADMIN_USERNAME=YourAdminUsername

# ── Telegram Notifications (optional) ─────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Discord Notifications (optional) ──────────────────────────
# DISCORD_WEBHOOK_URL=

# ── SMTP Mail (optional — required for email features) ────────
# SMTP_HOST=mail.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=KeeperLog <noreply@your-domain.com>

# ── Stripe (optional) ─────────────────────────────────────────
STRIPE_PAYMENT_ACTIVE=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PREMIUM_MONTHLY=
# STRIPE_PRICE_PREMIUM_YEARLY=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_YEARLY=
# STRIPE_PRICE_PRO_LIFETIME=

# ── Marketing tracking (Meta Pixel + Conversions API) ─────────
# See MARKETING_SETUP_GUIDE.md for full operator walkthrough.
#
# Safe rollout: leave META_CAPI_DRY_RUN=true on first deploy so payloads
# are logged but NOT sent to Meta. Flip to false after Test Events validation.
META_PIXEL_ENABLED=true
META_PIXEL_ID=CHANGE_ME_NUMERIC_PIXEL_ID
META_CAPI_ENABLED=true
META_CAPI_DRY_RUN=true
# System-user CAPI token — TREAT AS SECRET. Never commit, never log.
META_ACCESS_TOKEN=CHANGE_ME_META_CAPI_SYSTEM_USER_TOKEN
# Set during Test Events validation; remove for live production traffic.
META_TEST_EVENT_CODE=CHANGE_ME_OR_LEAVE_BLANK
# Must match frontend localStorage TTL (90d).
TRACKING_ATTRIBUTION_TTL_DAYS=90
TRACKING_PENDING_RESCUE_AFTER_SECONDS=120
TRACKING_ACTIVATION_WINDOW_DAYS=7
TRACKING_AUDIENCE_EXPORT_RETENTION_DAYS=30
TRACKING_DISPATCH_TIMEOUT_MS=5000
TRACKING_MAX_RETRY_COUNT=5
TRACKING_RETRY_BASE_DELAY_MS=5000
TRACKING_EVENT_RETENTION_DAYS=180
