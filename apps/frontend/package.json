{
    "name": "@cold-blood-cast/frontend",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "eslint --cache --cache-strategy content",
        "lint:fix": "eslint --cache --cache-strategy content --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "types:check": "tsc --noEmit",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:coverage": "rimraf .nyc_output e2e-coverage && cross-env E2E_COVERAGE=true playwright test && nyc report --temp-dir .nyc_output --report-dir e2e-coverage --reporter text --reporter text-summary --reporter html"
    },
    "dependencies": {
        "@nuxt/eslint": "^1.11.0",
        "@nuxt/hints": "^1.0.0-alpha.3",
        "@nuxt/icon": "^2.1.0",
        "@nuxt/image": "^2.0.0",
        "@nuxtjs/i18n": "^10.2.1",
        "@nuxtjs/sitemap": "^7.4.8",
        "@pinia/nuxt": "^0.11.3",
        "@tailwindcss/vite": "^4.1.17",
        "@tanstack/vue-query": "^5.95.2",
        "@vueuse/nuxt": "^14.1.0",
        "@cold-blood-cast/shared": "workspace:*",
        "dompurify": "^3.3.3",
        "marked": "^17.0.5",
        "nuxt": "^4.2.1",
        "nuxt-typed-router": "^4.0.2",
        "pinia": "^3.0.4",
        "tailwindcss": "^4.1.17",
        "vue": "^3.5.25",
        "vue-router": "^4.6.3",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.39.1",
        "@playwright/test": "^1.58.2",
        "@types/dompurify": "^3.2.0",
        "@types/eslint": "^9.6.1",
        "@types/node": "^24.10.1",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/coverage-v8": "^4.1.2",
        "@vue/test-utils": "^2.4.6",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.1",
        "happy-dom": "^20.8.4",
        "nyc": "^18.0.0",
        "prettier": "^3.7.4",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript": "^5.9.3",
        "vite-plugin-istanbul": "^8.0.0",
        "vitest": "^4.1.0",
        "vue-tsc": "^3.1.5"
    }
}
