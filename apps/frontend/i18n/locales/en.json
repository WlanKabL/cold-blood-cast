        "problem": {
            "label": "The reality",
            "title": "This is how most keepers lose control",
            "manual": {
                "title": "Manual Monitoring",
                "desc": "You check your terrarium twice a day, but have no idea what happens at night — temperature drops, humidity spikes, heater failures go unnoticed."
            },
            "blind": {
                "title": "Flying Blind",
                "desc": "You have no historical data. Was yesterday's humidity spike normal? Did the hot spot drop below safe levels last week? You'll never know."
            },
            "emergency": {
                "title": "Emergencies Undetected",
                "desc": "A sensor failure or heater malfunction could put your animal at risk for hours before you notice."
            },
            "transition": "There's a better way."
        },
        "features": {
            "label": "And there's more",
            "title": "Built for every part of your husbandry",
            "subtitle": "Sensors, alerts, feeding logs, shedding tracking — everything a responsible keeper needs, none of the complexity.",
            "sensors": {
                "title": "Multi-Sensor Support",
                "desc": "Connect DHT22, BME280, and other sensors via GPIO or Home Assistant. Monitor temperature, humidity, and pressure in real time."
            },
            "alerts": {
                "title": "Telegram Alerts",
                "desc": "Get notified instantly when conditions go out of safe range. Set thresholds per sensor and receive alerts on your phone."
            },
            "careLog": {
                "title": "Care Journal",
                "desc": "Log feedings, sheddings, and weight measurements. Track your reptile's health over time with searchable records."
            },
            "dashboard": {
                "title": "Live Dashboard",
                "desc": "See all your enclosures, sensors, and pet status at a glance. Real-time data via WebSockets — no refresh needed."
            }
        },
        "monitoring": {
            "label": "Sensor Monitoring",
            "title": "Every reading. Every minute. One place.",
            "desc": "KeeperLog polls your sensors continuously and stores every reading. See current values, historical trends, and spot anomalies before they become emergencies.",
            "point1": "Real-time temperature & humidity from DHT22 and BME280 sensors",
            "point2": "Home Assistant integration for additional sensor sources",
            "point3": "Historical data stored locally — review trends over days, weeks, months",
            "point4": "WebSocket-powered live updates on your dashboard"
        },
        "alertsDeep": {
            "label": "Alert System",
            "title": "Never miss a critical condition",
            "desc": "Define safe ranges for each sensor. When temperature drops too low or humidity spikes too high, KeeperLog sends you an alert via Telegram — instantly.",
            "point1": "Per-sensor thresholds with configurable min/max values",
            "point2": "Telegram notifications with cooldown to prevent spam",
            "point3": "Alert history to review past incidents",
            "point4": "Works 24/7 — even when you're asleep"
        },
        "comparison": {
            "label": "The difference",
            "title": "Before and after KeeperLog",
            "without": "Without KeeperLog",
            "with": "With KeeperLog",
            "manual": {
                "bad": "Checking thermometers twice a day and hoping nothing changed overnight",
                "good": "Continuous monitoring with alerts the moment something goes wrong"
            },
            "blind": {
                "bad": "No historical data — you can't tell if conditions are trending in the wrong direction",
                "good": "Full sensor logs with historical charts and trend analysis"
            },
            "care": {
                "bad": "Trying to remember when you last fed, when the last shed was, relying on memory",
                "good": "Complete digital care journal with feeding, shedding, and weight records"
            },
            "emergency": {
