        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.1",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/luxon": "^3.6.2",
        "@types/node": "^22.14.1",
        "@types/pg": "^8.20.0",
