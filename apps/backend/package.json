{
    "name": "@cold-blood-cast/backend",
    "version": "1.0.0",
    "private": true,
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "prisma generate && tsc",
        "start": "node dist/index.js",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "types:check": "prisma generate && tsc --noEmit",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:seed": "tsx prisma/seed.ts",
        "db:studio": "prisma studio",
        "db:reset": "prisma migrate reset",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@cold-blood-cast/shared": "workspace:*",
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "axios": "^1.14.0",
        "chalk": "^5.6.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^5.2.1",
        "express-api-to-postman": "^1.0.7",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "luxon": "^3.7.2",
        "p-queue": "^8.1.0",
        "pg": "^8.20.0",
        "prettier": "^3.8.1",
        "prisma": "^7.7.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "telegraf": "^4.16.3",
        "ws": "^8.20.0",
        "zod": "^3.24.3"
    },
    "devDependencies": {
