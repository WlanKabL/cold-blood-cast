{
    "name": "@cold-blood-cast/backend",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "tsx watch --env-file=.env src/server.ts",
        "build": "tsc --build && tsc-alias",
        "start": "node dist/server.js",
        "lint": "eslint --cache --cache-strategy content src/",
        "lint:fix": "eslint --cache --cache-strategy content --fix src/",
        "format": "prettier --check src/",
        "format:fix": "prettier --write src/",
        "types:check": "tsc --noEmit",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:migrate:status": "prisma migrate status",
        "db:migrate:reset": "prisma migrate reset",
        "db:push": "echo 'ERROR: db:push is disabled — use db:migrate instead to avoid schema drift and data loss' && exit 1",
        "db:seed": "tsx --env-file=.env src/config/seed.ts",
        "db:reseed": "tsx --env-file=.env src/config/seed.ts --reseed",
        "db:seed-demo": "tsx --env-file=.env src/config/seed-demo.ts",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate",
        "encrypt-uploads": "tsx --env-file=.env src/scripts/encrypt-uploads.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "db:setup": "prisma generate && prisma migrate dev && tsx --env-file=.env src/config/seed.ts"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.0.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/multipart": "^9.0.3",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/static": "^9.0.0",
        "@fastify/swagger": "^9.4.2",
        "@fastify/swagger-ui": "^5.2.5",
        "@fastify/websocket": "^11.0.2",
        "@prisma/client": "^6.5.0",
        "@cold-blood-cast/shared": "workspace:*",
        "archiver": "^7.0.1",
        "bullmq": "^5.70.4",
        "fastify": "^5.2.1",
        "fastify-raw-body": "^5.0.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.2",
        "ms": "^2.1.3",
        "node-cron": "^3.0.3",
        "nodemailer": "^8.0.1",
        "pino": "^9.6.0",
        "pino-pretty": "^13.1.3",
        "stripe": "^20.4.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.39.1",
        "@types/archiver": "^7.0.0",
        "@types/eslint": "^9.6.1",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/ms": "^2.1.0",
        "@types/node": "^24.10.1",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^7.0.11",
        "@vitest/coverage-v8": "^4.1.2",
        "dotenv": "^17.3.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.7.4",
        "prisma": "^6.5.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.19.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vitest": "^4.1.0"
    }
}
