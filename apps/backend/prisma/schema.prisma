generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ==========================================
// User & Auth
// ==========================================

model User {
    id           String   @id @default(cuid())
    username     String   @unique
    email        String   @unique
    passwordHash String   @map("password_hash")
    displayName  String?  @map("display_name")
    avatarUrl    String?  @map("avatar_url")
    banned       Boolean  @default(false)
    bannedAt     DateTime? @map("banned_at")
    bannedBy     String?  @map("banned_by")
    bannedReason String?  @map("banned_reason")
    approved     Boolean  @default(true)
    lastActiveAt DateTime? @map("last_active_at")

    // ── Email verification ───────────────────────
    emailVerified              Boolean   @default(false) @map("email_verified")
    verificationCode           String?   @map("verification_code")
    verificationCodeExpiresAt  DateTime? @map("verification_code_expires_at")

    // ── Password reset ───────────────────────────
    resetToken                 String?   @map("reset_token")
    resetTokenExpiresAt        DateTime? @map("reset_token_expires_at")

    // ── Account deletion ─────────────────────────
    deleteToken                String?   @map("delete_token")
    deleteTokenExpiresAt       DateTime? @map("delete_token_expires_at")

    // ── Username change ──────────────────────────
    usernameChangedAt          DateTime? @map("username_changed_at")

    // ── Email change ─────────────────────────────
    pendingEmail               String?   @map("pending_email")
    emailChangeCode            String?   @map("email_change_code")
    emailChangeCodeExpiresAt   DateTime? @map("email_change_code_expires_at")

    // ── Onboarding ───────────────────────────────
    onboardingCompleted        Boolean   @default(false) @map("onboarding_completed")

    // ── Email Preferences ────────────────────────
    weeklyReportEnabled        Boolean   @default(false) @map("weekly_report_enabled")
    weeklyReportDecidedAt      DateTime? @map("weekly_report_decided_at")

    // ── User Preferences ─────────────────────────
    locale                     String    @default("de") @db.VarChar(5)

    createdAt    DateTime @default(now()) @map("created_at")
    updatedAt    DateTime @updatedAt @map("updated_at")

    // ── Relations ────────────────────────────────
    roles                   UserRole[]
    featureFlags            UserFeatureFlag[]
    limitOverrides          UserLimitOverride[]
    apiKeys                 ApiKey[]
    refreshTokens           RefreshToken[]
    subscription            Subscription?
    emailLogs               EmailLog[]
    unsubscribeTokens       UnsubscribeToken[]
    legalDocumentEdits      LegalDocument[]       @relation("LegalDocumentUpdater")
    dataExports             DataExport[]
    cookieConsents          CookieConsent[]
    loginSessions           LoginSession[]
    uploads                 Upload[]

    // ── CBC Domain Relations ─────────────────────
    enclosures              Enclosure[]
    pets                    Pet[]
    sensors                 Sensor[]
    feedItems               FeedItem[]
    homeAssistantConfigs    HomeAssistantConfig[]
    alertRules              AlertRule[]
    veterinarians           Veterinarian[]
    vetVisits               VetVisit[]
    petDocuments            PetDocument[]
    maintenanceTasks        MaintenanceTask[]
    publicProfiles          PublicProfile[]
    userPublicProfile       UserPublicProfile?
    userBadges              UserBadge[]
    resolvedReports         ContentReport[]
    profileComments         ProfileComment[]
    tags                    Tag[]

    // ── Marketing attribution ───────────────────────
    userAttribution         UserAttribution?
    marketingEvents         MarketingEvent[]
    activationEvents        UserActivationEvent[]

    @@map("users")
}

model RefreshToken {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    revoked   Boolean  @default(false)
    expiresAt DateTime @map("expires_at")
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("refresh_tokens")
}

// ==========================================
// Roles & Permissions
// ==========================================

model Role {
    id          String  @id @default(cuid())
    name        String  @unique
    displayName String  @map("display_name")
    description String?
    color       String? @default("#6b7280")
    isSystem    Boolean @default(false) @map("is_system")
    priority    Int     @default(0)
    showBadge   Boolean @default(false) @map("show_badge")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    users        UserRole[]
    featureFlags RoleFeatureFlag[]
    limits       RoleLimit[]

    @@map("roles")
}

model UserRole {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    roleId    String   @map("role_id")
    grantedBy String?  @map("granted_by")
    grantedAt DateTime @default(now()) @map("granted_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

    @@unique([userId, roleId])
    @@map("user_roles")
}

// ==========================================
// Feature Flags
// ==========================================

model FeatureFlag {
    id          String  @id @default(cuid())
    key         String  @unique
    name        String
    description String?
    category    String  @default("general")
    enabled     Boolean @default(true)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    roleFlags RoleFeatureFlag[]
    userFlags UserFeatureFlag[]

    @@map("feature_flags")
}

model RoleFeatureFlag {
    id            String  @id @default(cuid())
    roleId        String  @map("role_id")
    featureFlagId String  @map("feature_flag_id")
    enabled       Boolean @default(true)

    role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
    featureFlag FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

    @@unique([roleId, featureFlagId])
    @@map("role_feature_flags")
}

model UserFeatureFlag {
    id            String  @id @default(cuid())
    userId        String  @map("user_id")
    featureFlagId String  @map("feature_flag_id")
    enabled       Boolean @default(true)
    grantedBy     String? @map("granted_by")

    createdAt DateTime @default(now()) @map("created_at")

    user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    featureFlag FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

    @@unique([userId, featureFlagId])
    @@map("user_feature_flags")
}

// ==========================================
// Limits (per Role / per User override)
// ==========================================

model RoleLimit {
    id     String @id @default(cuid())
    roleId String @map("role_id")
    key    String
    value  Int

    role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

    @@unique([roleId, key])
    @@map("role_limits")
}

model UserLimitOverride {
    id        String  @id @default(cuid())
    userId    String  @map("user_id")
    key       String
    value     Int
    grantedBy String? @map("granted_by")

    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, key])
    @@map("user_limit_overrides")
}

// ==========================================
// Audit Log
// ==========================================

model AuditLog {
    id        String   @id @default(cuid())
    userId    String?  @map("user_id")
    action    String
    entity    String?
    entityId  String?  @map("entity_id")
    details   Json?
    ipAddress String?  @map("ip_address")

    createdAt DateTime @default(now()) @map("created_at")

    @@index([userId])
    @@index([action])
    @@index([createdAt])
    @@map("audit_logs")
}

// ==========================================
// System Settings (key-value config)
// ==========================================

model SystemSetting {
    id    String @id @default(cuid())
    key   String @unique
    value String

    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("system_settings")
}

// ==========================================
// Invite Codes
// ==========================================

model InviteCode {
    id        String    @id @default(cuid())
    code      String    @unique
    createdBy String    @map("created_by")
    label     String?
    maxUses   Int       @default(1) @map("max_uses")
    uses      Int       @default(0)
    expiresAt DateTime? @map("expires_at")
    active    Boolean   @default(true)

    createdAt DateTime @default(now()) @map("created_at")

    usages InviteCodeUse[]

    @@index([code])
    @@index([active])
    @@map("invite_codes")
}

model InviteCodeUse {
    id           String   @id @default(cuid())
    inviteCodeId String   @map("invite_code_id")
    userId       String   @map("user_id")
    usedAt       DateTime @default(now()) @map("used_at")

    inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)

    @@index([inviteCodeId])
    @@map("invite_code_uses")
}

// ==========================================
// Access Requests (invite-only mode)
// ==========================================

model AccessRequest {
    id         String    @id @default(cuid())
    email      String
    reason     String?
    status     String    @default("pending")
    reviewedBy String?   @map("reviewed_by")
    reviewedAt DateTime? @map("reviewed_at")
    createdAt  DateTime  @default(now()) @map("created_at")

    @@index([status])
    @@index([email])
    @@map("access_requests")
}

// ==========================================
// Announcements
// ==========================================

model Announcement {
    id           String    @id @default(cuid())
    title        String
    content      String
    type         String    @default("info")
    global       Boolean   @default(true)
    targetUserId String?   @map("target_user_id")
    active       Boolean   @default(true)
    startsAt     DateTime? @map("starts_at")
    expiresAt    DateTime? @map("expires_at")
    createdBy    String    @map("created_by")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    readBy AnnouncementRead[]

    @@index([active, global])
    @@map("announcements")
}

model AnnouncementRead {
    id             String   @id @default(cuid())
    announcementId String   @map("announcement_id")
    userId         String   @map("user_id")
    readAt         DateTime @default(now()) @map("read_at")

    announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

    @@unique([announcementId, userId])
    @@map("announcement_reads")
}

// ==========================================
// Subscriptions (optional)
// ==========================================

model Subscription {
    id                   String    @id @default(cuid())
    userId               String    @unique @map("user_id")
    stripeCustomerId     String?   @unique @map("stripe_customer_id")
    stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
    stripePriceId        String?   @map("stripe_price_id")
    plan                 String    @default("free")
    status               String    @default("active")
    currentPeriodStart   DateTime? @map("current_period_start")
    currentPeriodEnd     DateTime? @map("current_period_end")
    cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("subscriptions")
}

// ==========================================
// API Keys
// ==========================================

model ApiKey {
    id        String    @id @default(cuid())
    userId    String    @map("user_id")
    name      String
    keyHash   String    @map("key_hash")
    prefix    String
    scopes    String[]  @default(["read"])
    lastUsedAt DateTime? @map("last_used_at")
    expiresAt  DateTime? @map("expires_at")
    revoked   Boolean   @default(false)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([keyHash])
    @@map("api_keys")
}

// ==========================================
// Email Log
// ==========================================

model EmailLog {
    id       String @id @default(cuid())
    to       String
    userId   String? @map("user_id")
    template String
    subject  String
    status   String @default("sent")
    sentBy   String? @map("sent_by")
    error    String?
    sentAt   DateTime @default(now()) @map("sent_at")

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([template])
    @@index([sentAt])
    @@map("email_logs")
}

// ==========================================
// Email Unsubscribe Tokens
// ==========================================

model UnsubscribeToken {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    token     String   @unique
    type      String
    used      Boolean  @default(false)
    usedAt    DateTime? @map("used_at")
    expiresAt DateTime @map("expires_at")
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([token])
    @@map("unsubscribe_tokens")
}

// ==========================================
// Legal Documents (admin-managed)
// ==========================================

model LegalDocument {
    id          String   @id @default(cuid())
    key         String   @unique
    title       String
    titleDe     String   @map("title_de")
    content     String   @db.Text
    contentDe   String   @map("content_de") @db.Text
    metadata    Json?
    isPublished Boolean  @default(false) @map("is_published")
    sortOrder   Int      @default(0) @map("sort_order")
    updatedAt   DateTime @updatedAt @map("updated_at")
    updatedBy   String?  @map("updated_by")

    updater User? @relation("LegalDocumentUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

    @@map("legal_documents")
}

// ==========================================
// GDPR Data Exports (Art. 15/20)
// ==========================================

model DataExport {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    status    String   @default("pending")
    filePath  String?  @map("file_path")
    token     String?  @unique
    expiresAt DateTime? @map("expires_at")
    error     String?
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([token])
    @@map("data_exports")
}

// ==========================================
// Login Sessions (device tracking)
// ==========================================

model LoginSession {
    id          String   @id @default(cuid())
    userId      String   @map("user_id")
    ipAddress   String   @map("ip_address")
    userAgent   String   @map("user_agent")
    fingerprint String
    createdAt   DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, fingerprint])
    @@map("login_sessions")
}

// ==========================================
// Cookie Consent (GDPR audit trail)
// ==========================================

model CookieConsent {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    analytics Boolean  @default(false)
    marketing Boolean  @default(false)
    version   Int
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("cookie_consents")
}

// ==========================================
// Marketing Tracking & Attribution
// ==========================================

model LandingAttribution {
    id               String   @id @default(cuid())
    landingSessionId String   @unique @map("landing_session_id")
    utmSource        String?  @map("utm_source")
    utmMedium        String?  @map("utm_medium")
    utmCampaign      String?  @map("utm_campaign")
    utmContent       String?  @map("utm_content")
    utmTerm          String?  @map("utm_term")
    fbclid           String?
    fbc              String?
    fbp              String?
    referrer         String?
    landingPath      String?  @map("landing_path")
    firstSeenAt      DateTime @default(now()) @map("first_seen_at")
    expiresAt        DateTime @map("expires_at")
    createdAt        DateTime @default(now()) @map("created_at")
    updatedAt        DateTime @updatedAt @map("updated_at")

    userAttributions UserAttribution[]

    @@index([utmSource, utmCampaign, utmContent])
    @@index([firstSeenAt])
    @@index([expiresAt])
    @@map("landing_attributions")
}

model UserAttribution {
    id                   String   @id @default(cuid())
    userId               String   @unique @map("user_id")
    landingAttributionId String   @map("landing_attribution_id")
    attributionModel     String   @default("first_touch") @map("attribution_model")
    boundAt              DateTime @default(now()) @map("bound_at")
    createdAt            DateTime @default(now()) @map("created_at")
    updatedAt            DateTime @updatedAt @map("updated_at")

    user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    landingAttribution LandingAttribution @relation(fields: [landingAttributionId], references: [id], onDelete: Restrict)

    @@index([landingAttributionId])
    @@index([boundAt])
    @@map("user_attributions")
}

model MarketingEvent {
    id                   String    @id @default(cuid())
    userId               String?   @map("user_id")
    landingSessionId     String?   @map("landing_session_id")
    eventName            String    @map("event_name")
    eventId              String    @map("event_id")
    eventSource          String    @map("event_source")
    metaEnabled          Boolean   @default(false) @map("meta_enabled")
    consentState         String    @map("consent_state")
    payload              Json?
    status               String    @default("pending")
    attemptCount         Int       @default(0) @map("attempt_count")
    nextRetryAt          DateTime? @map("next_retry_at")
    lastErrorCode        String?   @map("last_error_code")
    providerResponseCode Int?      @map("provider_response_code")
    failureReason        String?   @map("failure_reason")
    processingStartedAt  DateTime? @map("processing_started_at")
    lockToken            String?   @map("lock_token")
    sentAt               DateTime? @map("sent_at")
    createdAt            DateTime  @default(now()) @map("created_at")
    updatedAt            DateTime  @updatedAt @map("updated_at")

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@unique([eventName, eventId, eventSource])
    @@index([status, nextRetryAt])
    @@index([userId])
    @@index([landingSessionId])
    @@index([createdAt])
    @@index([eventName, status])
    @@map("marketing_events")
}

model UserActivationEvent {
    id             String   @id @default(cuid())
    userId         String   @map("user_id")
    activationType String   @map("activation_type")
    occurredAt     DateTime @default(now()) @map("occurred_at")
    metadata       Json?
    createdAt      DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, activationType])
    @@index([occurredAt])
    @@map("user_activation_events")
}

// ==========================================
// Cron Job Logs
// ==========================================

model CronJobLog {
    id        String   @id @default(cuid())
    jobName   String   @map("job_name")
    status    String
    attempts  Int      @default(1)
    details   Json?
    error     String?

    startedAt DateTime  @map("started_at")
    endedAt   DateTime? @map("ended_at")

    @@index([jobName, startedAt])
    @@map("cron_job_logs")
}

// ==========================================
// ==========================================
// CBC Domain: Veterinarians
// ==========================================

model Veterinarian {
    id         String  @id @default(cuid())
    userId     String  @map("user_id")
    name       String
    clinicName String? @map("clinic_name")
    address    String?
    phone      String?
    email      String?
    notes      String?

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    vetVisits VetVisit[]

    @@index([userId])
    @@map("veterinarians")
}

// ==========================================
// CBC Domain: Vet Visits
// ==========================================

model VetVisit {
    id              String       @id @default(cuid())
    petId           String       @map("pet_id")
    veterinarianId  String?      @map("veterinarian_id")
    userId          String       @map("user_id")
    sourceVisitId   String?      @map("source_visit_id")
    visitDate       DateTime     @map("visit_date")
    visitType       VetVisitType @default(OTHER) @map("visit_type")
    isAppointment   Boolean      @default(false) @map("is_appointment")
    reason          String?
    diagnosis       String?
    treatment       String?
    costCents       Int?         @map("cost_cents")
    weightGrams     Float?       @map("weight_grams")
    nextAppointment DateTime?    @map("next_appointment")
    notes           String?

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    pet          Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
    veterinarian Veterinarian?    @relation(fields: [veterinarianId], references: [id], onDelete: SetNull)
    user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    sourceVisit  VetVisit?        @relation("FollowUp", fields: [sourceVisitId], references: [id], onDelete: SetNull)
    followUps    VetVisit[]       @relation("FollowUp")
    documents    VetVisitDocument[]

    @@index([petId])
    @@index([userId])
    @@index([veterinarianId])
    @@index([sourceVisitId])
    @@index([userId, nextAppointment])
    @@map("vet_visits")
}

model VetVisitDocument {
    id         String  @id @default(cuid())
    vetVisitId String  @map("vet_visit_id")
    uploadId   String  @map("upload_id")
    label      String?

    createdAt DateTime @default(now()) @map("created_at")

    vetVisit VetVisit @relation(fields: [vetVisitId], references: [id], onDelete: Cascade)
    upload   Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

    @@index([vetVisitId])
    @@map("vet_visit_documents")
}

// ==========================================
// CBC Domain: Enums
// ==========================================

enum VetVisitType {
    CHECKUP
    EMERGENCY
    SURGERY
    VACCINATION
    DEWORMING
    FECAL_TEST
    CONSULTATION
    FOLLOW_UP
    OTHER

    @@map("vet_visit_type")
}

enum EnclosureType {
    TERRARIUM
    VIVARIUM
    AQUARIUM
    PALUDARIUM
    RACK
    OTHER
}

enum MaintenanceType {
    CLEANING
    SUBSTRATE_CHANGE
    LAMP_REPLACEMENT
    WATER_CHANGE
    FILTER_CHANGE
    DISINFECTION
    OTHER
}

enum Gender {
    MALE
    FEMALE
    UNKNOWN
}

enum SensorType {
    TEMPERATURE
    HUMIDITY
    PRESSURE
    WATER
}

enum AlertCondition {
    ABOVE
    BELOW
    OUTSIDE_RANGE
}

// ==========================================
// Uploads
// ==========================================

model Upload {
    id              String   @id @default(cuid())
    userId          String   @map("user_id")
    url             String
    originalName    String?  @map("original_name")
    caption         String?
    allowedUserIds  String[] @map("allowed_user_ids")

    createdAt       DateTime @default(now()) @map("created_at")
    updatedAt       DateTime @updatedAt @map("updated_at")

    user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    petPhotos       PetPhoto[]
    vetVisitDocuments VetVisitDocument[]
    petDocuments    PetDocument[]
    userPublicProfile UserPublicProfile?

    @@map("uploads")
}

// ==========================================
// CBC Domain: Enclosures (Terrarien)
// ==========================================

model Enclosure {
    id          String        @id @default(cuid())
    userId      String        @map("user_id")
    name        String
    type        EnclosureType @default(TERRARIUM)
    species     String?
    description String?
    imageUrl    String?       @map("image_url")
    lengthCm    Int?          @map("length_cm")
    widthCm     Int?          @map("width_cm")
    heightCm    Int?          @map("height_cm")
    room        String?
    active      Boolean       @default(true)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    pets    Pet[]
    sensors Sensor[]
    maintenanceTasks MaintenanceTask[]

    @@index([userId])
    @@map("enclosures")
}

// ==========================================
// CBC Domain: Enclosure Maintenance
// ==========================================

model MaintenanceTask {
    id           String          @id @default(cuid())
    enclosureId  String          @map("enclosure_id")
    userId       String          @map("user_id")
    type         MaintenanceType @default(OTHER)
    description  String?
    completedAt  DateTime?       @map("completed_at")
    nextDueAt    DateTime?       @map("next_due_at")
    intervalDays Int?            @map("interval_days")
    recurring    Boolean         @default(false)
    notes        String?

    createdAt    DateTime        @default(now()) @map("created_at")

    enclosure    Enclosure       @relation(fields: [enclosureId], references: [id], onDelete: Cascade)
    user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([enclosureId])
    @@index([userId])
    @@index([userId, nextDueAt])
    @@map("maintenance_tasks")
}

// ==========================================
// CBC Domain: Pets (Tiere)
// ==========================================

model Pet {
    id              String    @id @default(cuid())
    userId          String    @map("user_id")
    enclosureId     String?   @map("enclosure_id")
    name            String
    species         String
    morph           String?
    gender          Gender    @default(UNKNOWN)
    birthDate       DateTime? @map("birth_date")
    acquisitionDate DateTime? @map("acquisition_date")
    notes           String?
    imageUrl        String?   @map("image_url")

    feedingIntervalMinDays    Int?    @map("feeding_interval_min_days")
    feedingIntervalMaxDays    Int?    @map("feeding_interval_max_days")
    pauseFeedingDuringShed    Boolean @default(false) @map("pause_feeding_during_shed")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    enclosure     Enclosure?      @relation(fields: [enclosureId], references: [id], onDelete: SetNull)
    feedings      Feeding[]
    sheddings     Shedding[]
    weightRecords WeightRecord[]
    husbandryNotes HusbandryNote[] @relation("PetNotes")
    feedItems     FeedItem[]      @relation("PetFeedItems")
    photos        PetPhoto[]
    vetVisits     VetVisit[]
    documents     PetDocument[]
    publicProfile PublicProfile?
    userPetOrders UserPetOrder[]
    tags          Tag[]           @relation("PetTags")

    @@index([userId])
    @@index([enclosureId])
    @@map("pets")
}

// ==========================================
// CBC Domain: Pet Photos
// ==========================================

model PetPhoto {
    id               String   @id @default(cuid())
    petId            String   @map("pet_id")
    uploadId         String   @map("upload_id")
    caption          String?
    tags             String[] @default([])
    isProfilePicture Boolean  @default(false) @map("is_profile_picture")
    sortOrder        Int      @default(0) @map("sort_order")
    takenAt          DateTime @default(now()) @map("taken_at")

    createdAt        DateTime @default(now()) @map("created_at")

    pet              Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
    upload           Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

    @@index([petId])
    @@index([petId, isProfilePicture])
    @@map("pet_photos")
}

// ==========================================
// CBC Domain: Pet Documents
// ==========================================

enum PetDocumentCategory {
    PURCHASE_RECEIPT
    CITES
    ORIGIN_CERTIFICATE
    VET_REPORT
    INSURANCE
    OTHER
}

model PetDocument {
    id           String              @id @default(cuid())
    petId        String              @map("pet_id")
    userId       String              @map("user_id")
    uploadId     String              @map("upload_id")
    category     PetDocumentCategory @default(OTHER)
    label        String?
    notes        String?
    documentDate DateTime?           @map("document_date")

    createdAt    DateTime            @default(now()) @map("created_at")

    pet          Pet                 @relation(fields: [petId], references: [id], onDelete: Cascade)
    user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
    upload       Upload              @relation(fields: [uploadId], references: [id], onDelete: Cascade)

    @@index([petId])
    @@index([petId, category])
    @@map("pet_documents")
}

// ==========================================
// CBC Domain: Feeding Log
// ==========================================

model Feeding {
    id         String    @id @default(cuid())
    petId      String    @map("pet_id")
    feedItemId String?   @map("feed_item_id")
    fedAt      DateTime  @map("fed_at")
    foodType   String    @map("food_type")
    foodSize   String?   @map("food_size")
    quantity   Int       @default(1)
    accepted   Boolean   @default(true)
    refusedReason String? @map("refused_reason")
    retryAt    DateTime? @map("retry_at")
    notes      String?
    createdAt  DateTime  @default(now()) @map("created_at")

    pet      Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
    feedItem FeedItem? @relation(fields: [feedItemId], references: [id], onDelete: SetNull)

    @@index([petId, fedAt])
    @@index([feedItemId])
    @@map("feedings")
}

// ==========================================
// CBC Domain: Feed Items (Futtertiere)
// ==========================================

model FeedItem {
    id          String  @id @default(cuid())
    userId      String  @map("user_id")
    name        String
    size        String?
    weightGrams Float?  @map("weight_grams")
    notes       String?

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    suitablePets Pet[]    @relation("PetFeedItems")
    feedings    Feeding[]

    @@index([userId])
    @@map("feed_items")
}

// ==========================================
// CBC Domain: Shedding Log
// ==========================================

model Shedding {
    id          String    @id @default(cuid())
    petId       String    @map("pet_id")
    startedAt   DateTime  @map("started_at")
    completedAt DateTime? @map("completed_at")
    complete    Boolean   @default(false)
    quality     String?
    notes       String?
    createdAt   DateTime  @default(now()) @map("created_at")

    pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

    @@index([petId, startedAt])
    @@map("sheddings")
}

// ==========================================
// CBC Domain: Weight Tracking
// ==========================================

model WeightRecord {
    id          String   @id @default(cuid())
    petId       String   @map("pet_id")
    measuredAt  DateTime @map("measured_at")
    weightGrams Float    @map("weight_grams")
    notes       String?
    createdAt   DateTime @default(now()) @map("created_at")

    pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

    @@index([petId, measuredAt])
    @@map("weight_records")
}

// ==========================================
// CBC Domain: Husbandry Notes
// ==========================================

model HusbandryNote {
    id          String   @id @default(cuid())
    petId       String?  @map("pet_id")
    type        String
    title       String
    content     String?
    occurredAt  DateTime @map("occurred_at")
    createdAt   DateTime @default(now()) @map("created_at")

    pet Pet? @relation("PetNotes", fields: [petId], references: [id], onDelete: Cascade)

    @@index([petId])
    @@map("husbandry_notes")
}

// ==========================================
// CBC Domain: Sensors & Readings
// ==========================================

model Sensor {
    id                    String     @id @default(cuid())
    userId                String     @map("user_id")
    enclosureId           String?    @map("enclosure_id")
    name                  String
    type                  SensorType
    unit                  String
    homeAssistantEntityId String?    @map("ha_entity_id")
    limitsJson            Json?      @map("limits_json")
    active                Boolean    @default(true)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    enclosure Enclosure? @relation(fields: [enclosureId], references: [id], onDelete: SetNull)
    readings  SensorReading[]
    alerts    AlertRule[]

    @@index([userId])
    @@index([enclosureId])
    @@map("sensors")
}

model SensorReading {
    id         String   @id @default(cuid())
    sensorId   String   @map("sensor_id")
    value      Float?
    recordedAt DateTime @map("recorded_at")

    sensor Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)

    @@index([sensorId, recordedAt])
    @@map("sensor_readings")
}

// ==========================================
// CBC Domain: Home Assistant Config
// ==========================================

model HomeAssistantConfig {
    id        String  @id @default(cuid())
    userId    String  @map("user_id")
    url       String
    token     String
    active    Boolean @default(true)
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("home_assistant_configs")
}

// ==========================================
// CBC Domain: Alert Rules
// ==========================================

model AlertRule {
    id              String         @id @default(cuid())
    userId          String         @map("user_id")
    sensorId        String         @map("sensor_id")
    condition       AlertCondition
    threshold       Float?
    thresholdLow    Float?         @map("threshold_low")
    thresholdHigh   Float?         @map("threshold_high")
    cooldownMinutes Int            @default(30) @map("cooldown_minutes")
    enabled         Boolean        @default(true)
    lastTriggeredAt DateTime?      @map("last_triggered_at")
    createdAt       DateTime       @default(now()) @map("created_at")

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    sensor Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)

    @@index([sensorId])
    @@map("alert_rules")
}

// ==========================================
// CBC Domain: Presets (system-wide)
// ==========================================

model Preset {
    id          String   @id @default(cuid())
    name        String   @unique
    species     String
    description String?
    sensorsJson Json     @map("sensors_json")
    createdAt   DateTime @default(now()) @map("created_at")

    @@map("presets")
}

// ==========================================
// CBC Domain: Telegram
// ==========================================

model TelegramSubscriber {
    id        String   @id @default(cuid())
    chatId    BigInt   @unique @map("chat_id")
    userId    String?  @map("user_id")
    createdAt DateTime @default(now()) @map("created_at")

    @@map("telegram_subscribers")
}

model TelegramRegistrationKey {
    id        String   @id @default(cuid())
    key       String   @unique
    createdAt DateTime @default(now()) @map("created_at")

    @@map("telegram_registration_keys")
}

// ==========================================
// CBC Domain: Public Pet Profiles
// ==========================================

model PublicProfile {
    id            String  @id @default(cuid())
    petId         String  @unique @map("pet_id")
    userId        String  @map("user_id")
    slug          String
    active        Boolean @default(false)
    bio           String?

    // ── Visibility Toggles ───────────────────────
    showPhotos    Boolean @default(true) @map("show_photos")
    showWeight    Boolean @default(true) @map("show_weight")
    showAge       Boolean @default(true) @map("show_age")
    showFeedings  Boolean @default(true) @map("show_feedings")
    showSheddings Boolean @default(true) @map("show_sheddings")
    showSpecies   Boolean @default(true) @map("show_species")
    showMorph     Boolean @default(true) @map("show_morph")

    // ── Stats ────────────────────────────────────
    views         Int      @default(0)

    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    // ── Relations ────────────────────────────────
    pet           Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
    user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, slug])
    @@index([userId])
    @@map("public_profiles")
}

// ==========================================
// User Public Profiles
// ==========================================

model UserPublicProfile {
    id              String   @id @default(cuid())
    userId          String   @unique @map("user_id")
    slug            String   @unique
    active          Boolean  @default(false)

    // ── Profil-Infos ─────────────────────────────
    bio             String?  @db.VarChar(1000)
    tagline         String?  @db.VarChar(100)
    location        String?  @db.VarChar(100)
    keeperSince     DateTime? @map("keeper_since")

    // ── Avatar ───────────────────────────────────
    avatarUploadId  String?  @unique @map("avatar_upload_id")

    // ── Visibility Toggles ───────────────────────
    showStats       Boolean  @default(true) @map("show_stats")
    showPets        Boolean  @default(true) @map("show_pets")
    showSocialLinks Boolean  @default(true) @map("show_social_links")
    showLocation    Boolean  @default(true) @map("show_location")
    showKeeperSince Boolean  @default(true) @map("show_keeper_since")
    showBadges      Boolean  @default(true) @map("show_badges")

    // ── Theme ────────────────────────────────────
    themePreset     String   @default("default") @map("theme_preset") @db.VarChar(30)

    // ── Notification Preferences ─────────────────
    notifyOnComment Boolean  @default(false) @map("notify_on_comment")

    // ── Stats ────────────────────────────────────
    views           Int      @default(0)

    createdAt       DateTime @default(now()) @map("created_at")
    updatedAt       DateTime @updatedAt @map("updated_at")

    // ── Relations ────────────────────────────────
    user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    avatarUpload    Upload?          @relation(fields: [avatarUploadId], references: [id], onDelete: SetNull)
    socialLinks     UserSocialLink[]
    petOrder        UserPetOrder[]

    @@map("user_public_profiles")
}

model UserSocialLink {
    id              String  @id @default(cuid())
    profileId       String  @map("profile_id")
    platform        String  @db.VarChar(30)
    url             String  @db.VarChar(500)
    label           String? @db.VarChar(50)
    sortOrder       Int     @default(0) @map("sort_order")

    profile         UserPublicProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    @@index([profileId])
    @@map("user_social_links")
}

model UserPetOrder {
    id          String  @id @default(cuid())
    profileId   String  @map("profile_id")
    petId       String  @map("pet_id")
    sortOrder   Int     @default(0) @map("sort_order")

    profile     UserPublicProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
    pet         Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)

    @@unique([profileId, petId])
    @@index([profileId])
    @@map("user_pet_order")
}

// ==========================================
// Badges & Achievements
// ==========================================

model Badge {
    id          String  @id @default(cuid())
    key         String  @unique
    nameKey     String  @map("name_key")
    descKey     String  @map("desc_key")
    icon        String
    category    String  @default("general")
    threshold   Int?
    sortOrder   Int     @default(0) @map("sort_order")

    userBadges  UserBadge[]

    @@map("badges")
}

model UserBadge {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    badgeId   String   @map("badge_id")
    earnedAt  DateTime @default(now()) @map("earned_at")

    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

    @@unique([userId, badgeId])
    @@map("user_badges")
}

// ==========================================
// Community: Likes & Comments
// ==========================================

model ProfileLike {
    id          String   @id @default(cuid())
    profileType String   @map("profile_type") @db.VarChar(10)
    profileId   String   @map("profile_id")
    ipHash      String   @map("ip_hash")
    createdAt   DateTime @default(now()) @map("created_at")

    @@unique([profileType, profileId, ipHash])
    @@index([profileType, profileId])
    @@map("profile_likes")
}

model ProfileComment {
    id          String   @id @default(cuid())
    profileType String   @map("profile_type") @db.VarChar(10)
    profileId   String   @map("profile_id")
    authorId    String?  @map("author_id")
    authorName  String   @map("author_name") @db.VarChar(50)
    content     String   @db.VarChar(500)
    approved    Boolean  @default(false)
    createdAt   DateTime @default(now()) @map("created_at")

    author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

    @@index([profileType, profileId])
    @@index([authorId])
    @@map("profile_comments")
}

// ==========================================
// Content Reports
// ==========================================

model ContentReport {
    id            String    @id @default(cuid())
    targetType    String    @map("target_type") @db.VarChar(20) // "comment", "user_profile", "pet_profile"
    targetId      String    @map("target_id")
    targetUrl     String?   @map("target_url") @db.VarChar(500)
    reason        String    @db.VarChar(100)
    description   String?   @db.VarChar(1000)
    reporterName  String?   @map("reporter_name") @db.VarChar(50)
    status        String    @default("pending") @db.VarChar(20) // "pending", "reviewed", "dismissed"
    adminNote     String?   @map("admin_note") @db.VarChar(1000)
    resolvedAt    DateTime? @map("resolved_at")
    resolvedById  String?   @map("resolved_by_id")
    createdAt     DateTime  @default(now()) @map("created_at")

    resolvedBy    User?     @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

    @@index([targetType, targetId])
    @@index([status])
    @@map("content_reports")
}

// ==========================================
// Tags
// ==========================================

model Tag {
    id        String   @id @default(cuid())
    name      String   @db.VarChar(50)
    userId    String?  @map("user_id")
    category  String   @db.VarChar(30)
    color     String?  @db.VarChar(7)
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
    pets      Pet[]    @relation("PetTags")

    @@unique([userId, name, category])
    @@index([category])
    @@index([userId])
    @@map("tags")
}
