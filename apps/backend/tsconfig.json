{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "lib": ["ES2022"],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "baseUrl": "."
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "prisma"],
    "references": [
        // Build shared first so declaration files (.d.ts) are available during
        // the backend tsc compilation. Works in all environments (local + Docker)
        // because tsc --build handles the full dependency chain.
        { "path": "../../packages/shared" }
    ]
}
