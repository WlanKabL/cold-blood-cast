# Port for the HTTP server
PORT=3001

# Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://coldblood:coldblood@localhost:5432/coldbloodcast"

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# Frontend URL (used for links in emails)
FRONTEND_URL=http://localhost:3000

# JWT secrets (min 32 chars each — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_ACCESS_SECRET=change_me_to_a_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_strong_random_string_min_32

# JWT token expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Pepper for password hashing (min 32 chars)
HASH_PEPPER=change_me_to_yet_another_strong_random_string_32
HASH_ITERATIONS=100000

# Cookie signing secret (min 32 chars)
COOKIE_SECRET=change_me_cookie_secret_min_32_characters

# Encryption key (AES-256, 32 bytes hex — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=change_me_encryption_key_64_hex_chars_here_now

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Admin user seeding (promoted to ADMIN + PREMIUM on `pnpm db:seed`)
ADMIN_EMAIL=your_admin@example.com
ADMIN_USERNAME=YourAdminUsername

# ── Telegram Notifications (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord Notifications (optional) ──
DISCORD_WEBHOOK_URL=

# ── SMTP Mail (optional — required for email features) ──
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=KeeperLog <noreply@example.com>

# ── Redis (BullMQ job queue) ──
REDIS_URL=redis://localhost:6379

# ── Stripe (optional) ──
STRIPE_PAYMENT_ACTIVE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_LIFETIME=