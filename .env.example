# ── Docker Compose ──
# These vars are used by docker-compose.yml for the Postgres container.
# The backend reads its own .env from apps/backend/.env

# ── Server ──
PORT=3301
NODE_ENV=development
CORS_ORIGINS=http://localhost:3300

# ── Database (Docker Compose) ──
DATABASE_URL=postgresql://coldblood:coldblood@localhost:5432/coldbloodcast
POSTGRES_USER=coldblood
POSTGRES_PASSWORD=coldblood
POSTGRES_DB=coldbloodcast

# ── Auth (min 32 chars each — see apps/backend/.env.example for full list) ──
JWT_ACCESS_SECRET=change_me_to_a_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_strong_random_string_min_32
PEPPER=change_me_to_yet_another_strong_random_string_32

# ── Telegram (optional) ──
TELEGRAM_BOT_TOKEN=
DISABLE_TELEGRAM_BOT=true

# ── Home Assistant (optional) ──
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your_ha_long_lived_access_token
