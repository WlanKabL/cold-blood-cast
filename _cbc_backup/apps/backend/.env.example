# ── Server ──
PORT=3001
NODE_ENV=development
DATA_DIR=./data
CORS_ORIGINS=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://coldblood:changeme@localhost:5432/coldbloodcast

# ── Auth (min 32 chars each) ──
JWT_ACCESS_SECRET=change_me_to_a_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_strong_random_string_min_32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PEPPER=change_me_to_yet_another_strong_random_string_32

# ── Sensor ──
USE_MOCK=true

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DISABLE_TELEGRAM_BOT=true

# ── Home Assistant ──
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your_ha_long_lived_access_token